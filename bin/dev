#!/usr/bin/env bash

set -e

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  echo "Usage: bin/dev [-b | -f | -a]"
  echo ""
  echo "  -b    Run backend (Go)"
  echo "  -f    Run frontend (Next.js)"
  echo "  -a    Run both backend and frontend"
  exit 1
}

run_backend() {
  echo "[backend] Tidying Go modules..."
  cd "$ROOT/backend" && go mod tidy
  echo "[backend] Starting Go server..."
  go run ./cmd/main.go
}

run_frontend() {
  echo "[frontend] Installing dependencies..."
  cd "$ROOT/frontend" && pnpm install
  echo "[frontend] Starting Next.js dev server..."
  pnpm dev
}

run_both() {
  echo "[dev] Setting up and starting backend and frontend..."

  trap 'kill 0' INT TERM

  (
    echo "[backend] Tidying Go modules..."
    cd "$ROOT/backend" && go mod tidy
    echo "[backend] Starting Go server..."
    go run ./cmd/main.go
  ) &

  (
    echo "[frontend] Installing dependencies..."
    cd "$ROOT/frontend" && pnpm install
    echo "[frontend] Starting Next.js dev server..."
    pnpm dev
  ) &

  wait
}

case "${1:-}" in
  -b)
    run_backend
    ;;
  -f)
    run_frontend
    ;;
  -a)
    run_both
    ;;
  "")
    echo ""
    echo "  shrinkly dev runner"
    echo ""
    echo "  Usage:"
    echo "    bin/dev <flag>"
    echo ""
    echo "  Flags:"
    echo "    -b    Run backend only  (Go server)"
    echo "    -f    Run frontend only (Next.js)"
    echo "    -a    Run both backend and frontend"
    echo ""
    echo "  Examples:"
    echo "    bin/dev -b"
    echo "    bin/dev -f"
    echo "    bin/dev -a"
    echo ""
    ;;
  *)
    usage
    ;;
esac
